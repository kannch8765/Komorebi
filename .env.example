# Komorebi — example environment file
#
# Copy to `.env` and fill in your real values. `.env` is gitignored.
#
# In production (Cloud Run, Railway, Render, etc.) set these via the
# platform's secret manager / env-var config UI — DO NOT commit a `.env`
# with real keys to git.

# --- LLM -------------------------------------------------------------------
# ADK reads GOOGLE_API_KEY first; GEMINI_API_KEY is the legacy alias.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-key-here
# GEMINI_API_KEY=legacy-alias

# --- Places (Google Places API New) ----------------------------------------
# Used by places_agent. Required for cafe/park/library recommendations.
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your-google-places-key-here

# --- Server ----------------------------------------------------------------
# Cloud Run sets PORT automatically; the default 8080 is fine everywhere else.
# PORT=8080

# --- Personal context (V2.5, optional) -------------------------------------
# If you want a saved home / profile without going through the REPL's `/home`
# slash command, set these. The REPL will read them on first run.
# KOMOREBI_HOME_LABEL=横浜駅
# KOMOREBI_HOME_LAT=35.4657
# KOMOREBI_HOME_LON=139.6223